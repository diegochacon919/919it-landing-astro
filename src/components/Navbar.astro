    transition: width 0.25s ease;
  }

  .navbar__links a:not(.nav-cta):hover::after { width: 100%; }

  .navbar__links a:not(.nav-cta):hover { color: var(--text-main); }

  .nav-cta {
    padding: 8px 18px !important;
